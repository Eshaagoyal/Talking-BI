# Supabase Postgres connection (Settings → Database → URI, or pooler URL)
SUPABASE_DB_URL=postgresql://user:password@host:5432/postgres

# Google AI (Gemini) for NL→SQL, layout, chat
GEMINI_API_KEY=

# Comma-separated browser origins for CORS, or * for development
# Example production: https://myapp.netlify.app,https://www.myapp.com
CORS_ORIGINS=*
